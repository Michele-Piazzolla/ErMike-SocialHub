<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ErMike-SocialHub · Registrati</title>
  <%- include('partials/styles') %>
  <style>
    body {
      display:         flex;
      align-items:     center;
      justify-content: center;
      min-height:      100vh;
    }

    .auth-box {
      width:         min(92vw, 380px);
      background:    var(--bg-card);
      border:        1px solid var(--border);
      border-top:    3px solid var(--green);  /* accento verde */
      border-radius: 10px;
      padding:       2rem 1.8rem;
    }

    .auth-title    { text-align:center; font-size:1.6rem; font-weight:900; color:var(--yellow); margin-bottom:0.3rem; }
    .auth-subtitle { text-align:center; color:var(--muted); font-size:0.85rem; margin-bottom:1.5rem; }
    .form-group    { margin-bottom: 1rem; }
    label          { display:block; font-size:0.82rem; color:#aaa; margin-bottom:0.3rem; }
    .hint          { font-size:0.76rem; color:var(--muted); margin-top:0.25rem; }
  </style>
</head>
<body>

  <div class="auth-box">
    <div class="auth-title">📸 ErMike</div>
    <div class="auth-subtitle">Crea il tuo account</div>

    <% if (error) { %>
      <div class="alert-error">⚠️ <%= error %></div>
    <% } %>

    <!-- Form registrazione: invia POST a /register -->
    <form method="POST" action="/register">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="Scegli un username" required autofocus minlength="3">
        <div class="hint">Minimo 3 caratteri · niente spazi</div>
      </div>
      <div class="form-group" style="margin-bottom:1.5rem;">
        <label>Password</label>
        <input type="password" name="password" placeholder="Scegli una password" required minlength="4">
        <div class="hint">Minimo 4 caratteri</div>
      </div>
      <button type="submit" class="btn btn-green btn-full">Crea account</button>
    </form>

    <!-- Nota: l'ID univoco viene generato automaticamente dal server (non visibile all'utente) -->

    <p class="text-center mt-2" style="font-size:0.88rem; color:var(--muted);">
      Hai già un account? <a href="/login">Accedi</a>
    </p>
  </div>

</body>
</html>
