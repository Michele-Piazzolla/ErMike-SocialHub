<body class="chat-page">

  <%- include('partials/navbar') %>
<div class="chat-page-wrap"> <!-- BRAZY SHIT -->
  <!-- Indicatore stato connessione WebSocket -->
  <div class="conn-status" id="connStatus">⏳ Connessione in corso…</div>

  <div class="chat-title">🌍 Chat Globale — tutti possono leggere e scrivere</div>

  <!-- Area messaggi — popolata da JavaScript -->
  <div class="messages" id="messages"></div>

  <!-- Barra invio -->
  <div class="input-bar">
    <input type="text" id="msgInput"
           placeholder="Scrivi un messaggio…" disabled
           maxlength="500">
    <button class="btn btn-green" id="sendBtn" disabled onclick="inviaMessaggio()">
      Invia
    </button>
  </div>
</div>
  <script>
    /*
      ══════════════════════════════════════════════
      LOGICA CHAT WEBSOCKET
      Basata sul tuo vecchio progetto chat, ripulita.
      Protocollo messaggi (server → client):
        tipo 1 → storico iniziale  { tipo:1, storico:[...] }
        tipo 2 → nuovo messaggio   { tipo:2, msg:{...} }
        tipo -1 → errore            { tipo:-1, errore:"..." }
      Protocollo messaggi (client → server):
        tipo 0 → autenticazione    { tipo:0, username:"..." }
        tipo 1 → invia messaggio   { tipo:1, testo:"..." }
      ══════════════════════════════════════════════
    */

    /* Username dell'utente corrente (iniettato da EJS) */
    const ME = '<%= user.username %>';

    const msgInput  = document.getElementById('msgInput');
    const sendBtn   = document.getElementById('sendBtn');
    const messages  = document.getElementById('messages');
    const connStatus = document.getElementById('connStatus');

    /* Connessione WebSocket al server (stesso host, stessa porta) */
    const ws = new WebSocket('ws://' + location.host);

    /* ── Connessione aperta ── */
    ws.onopen = () => {
      /* Invia subito l'autenticazione con il nostro username */
      ws.send(JSON.stringify({ tipo: 0, username: ME }));
    };

    /* ── Messaggio ricevuto dal server ── */
    ws.onmessage = event => {
      const dati = JSON.parse(event.data);

      /* Storico iniziale: carica tutti i messaggi passati */
      if (dati.tipo === 1) {
        messages.innerHTML = '';
        dati.storico.forEach(aggiungiBolla);
        scorriGiu();

        /* Abilita l'input ora che siamo connessi */
        msgInput.disabled = false;
        sendBtn.disabled  = false;
        msgInput.focus();
        connStatus.textContent = '🟢 Connesso come ' + ME;
        connStatus.classList.remove('disconnesso');
      }

      /* Nuovo messaggio in arrivo in tempo reale */
      else if (dati.tipo === 2) {
        aggiungiBolla(dati.msg);
        scorriGiu();
      }

      /* Errore (es. username già connesso) */
      else if (dati.tipo === -1) {
        connStatus.textContent = '🔴 ' + dati.errore;
        connStatus.classList.add('disconnesso');
      }
    };

    /* ── Disconnessione ── */
    ws.onclose = () => {
      msgInput.disabled = true;
      sendBtn.disabled  = true;
      connStatus.textContent = '🔴 Disconnesso · ricarica la pagina';
      connStatus.classList.add('disconnesso');
    };

    /* ── Crea e aggiunge una bolla nella chat ── */
    function aggiungiBolla(msg) {
      const isMio = msg.username === ME;

      /* Formatta l'orario */
      const ora = new Date(msg.timestamp).toLocaleTimeString('it-IT', {
        hour: '2-digit', minute: '2-digit'
      });

      /* Riga contenitore (mine = mio, other = altrui) */
      const riga = document.createElement('div');
      riga.className = 'msg-row ' + (isMio ? 'mine' : 'other');

      /* Username (solo per i messaggi altrui) */
      if (!isMio) {
        const user = document.createElement('div');
        user.className   = 'msg-username';
        user.textContent = '@' + msg.username;
        riga.appendChild(user);
      }

      /* Bolla testo */
      const bubble = document.createElement('div');
      bubble.className   = 'bubble';
      bubble.textContent = msg.testo;   // textContent evita XSS
      riga.appendChild(bubble);

      /* Orario */
      const time = document.createElement('div');
      time.className   = 'msg-time';
      time.textContent = ora;
      riga.appendChild(time);

      messages.appendChild(riga);
    }

    /* ── Scorri in fondo dopo ogni messaggio ── */
    function scorriGiu() {
      messages.scrollTop = messages.scrollHeight;
    }

    /* ── Invia messaggio ── */
    function inviaMessaggio() {
      const testo = msgInput.value.trim();
      if (!testo) return;

      ws.send(JSON.stringify({ tipo: 1, testo }));
      msgInput.value = '';
      msgInput.focus();
    }

    /* Invia anche premendo Invio (senza Shift) */
    msgInput.addEventListener('keydown', e => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        inviaMessaggio();
      }
    });
  </script>

</body>
</html>
