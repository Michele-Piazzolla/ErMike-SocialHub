<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Profilo · <%= user.username %></title>
  <%- include('partials/styles') %>

    <link rel="stylesheet" href="/css/style.css">


  <!--<style>
    /* ── Layout pagina ── */
