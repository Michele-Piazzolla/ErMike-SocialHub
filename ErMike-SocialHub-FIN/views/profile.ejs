    .avatar-wrap { flex-shrink: 0; }
    .avatar {
      width:         100px;
      height:        100px;
      object-fit:    cover;
      border-radius: 50%;
      border:        3px solid var(--yellow);
      display:       block;
    }
    /* Placeholder se non c'è avatar: cerchio con iniziale */
    .avatar-placeholder {
      width:           100px;
      height:          100px;
      border-radius:   50%;
      border:          3px solid var(--yellow);
      background:      var(--blue);
      color:           #fff;
      font-size:       2.2rem;
      font-weight:     800;
      display:         flex;
      align-items:     center;
      justify-content: center;
    }

    /* Info testo a destra dell'avatar */
    .profile-info    { flex: 1; min-width: 180px; }
    .profile-username {
      font-size:     1.6rem;
      font-weight:   800;
      color:         var(--yellow);
      margin-bottom: 0.2rem;
    }
    .profile-fullname { font-weight: 600; color: var(--text); margin-bottom: 0.3rem; }
    .profile-bio      { color: var(--muted); font-size: 0.9rem; line-height: 1.5; }

    /* Contatore post */
    .profile-stats {
      display:     flex;
      gap:         1.5rem;
      margin-top:  0.8rem;
    }
    .stat { text-align: center; }
    .stat-num   { font-size: 1.3rem; font-weight: 800; color: var(--text); display: block; }
    .stat-label { font-size: 0.75rem; color: var(--muted); }

    /* ── Form modifica profilo ── */
    .edit-section {
      display:       none;          /* nascosto di default, toggle via JS */
      margin-top:    1.2rem;
      border-top:    1px solid #2a2a2a;
      padding-top:   1.2rem;
    }
    .edit-section.open { display: block; }
    .edit-section h3   { color: var(--yellow); margin-bottom: 1rem; font-size: 1rem; }

    label { display: block; font-size: 0.82rem; color: #aaa; margin-bottom: 0.3rem; margin-top: 0.9rem; }
    label:first-of-type { margin-top: 0; }

    .btn-row { display: flex; gap: 0.6rem; margin-top: 1rem; flex-wrap: wrap; }

    /* ── Post del profilo ── */
    .posts-title {
      font-size:     0.95rem;
      font-weight:   700;
      color:         var(--yellow);
      border-bottom: 1px solid #2a2a2a;
