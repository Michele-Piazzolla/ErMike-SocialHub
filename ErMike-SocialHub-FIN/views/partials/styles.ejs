<style>
/* ══════════════════════════════════════════════
   ErMike-SocialHub — Stile globale condiviso
   Tema: sfondo nero, accenti colorati sui bordi
   ══════════════════════════════════════════════ */
/*<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
/* Variabili colore — modificale qui per cambiare tutto il tema */
:root {
  --bg:        #0d0d0d;   /* sfondo pagina */
  --bg-card:   #1a1a1a;   /* sfondo card/div */
  --bg-input:  #222222;   /* sfondo input */
  --border:    #2e2e2e;   /* bordo neutro */
  --text:      #e8e8e8;   /* testo principale */
  --muted:     #777;      /* testo secondario / data */
  /* Colori accento */
  --red:       #e53935;
  --blue:      #1e88e5;
  --green:     #00e676;   /* lime green */
  --yellow:    #ffd600;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color:       var(--text);
  font-family: 'Segoe UI', system-ui, sans-serif;
  font-size:   15px;
  min-height:  100vh;
}

/* ── Link generici ── */
a { color: var(--blue); text-decoration: none; }
a:hover { text-decoration: underline; }

/* ── Input e textarea ── */
input[type="text"],
input[type="password"],
input[type="email"],
textarea {
  width:         100%;
  background:    var(--bg-input);
  border:        1px solid var(--border);
  border-radius: 6px;
  color:         var(--text);
  padding:       0.5rem 0.75rem;
  font-size:     0.9rem;
  font-family:   inherit;
  outline:       none;
  transition:    border-color 0.2s;
}
input:focus, textarea:focus { border-color: var(--blue); }

/* ── Bottoni ── */
.btn {
  display:       inline-block;
  padding:       0.5rem 1.2rem;
  border-radius: 6px;
  border:        none;
  font-weight:   600;
  font-size:     0.9rem;
  cursor:        pointer;
  transition:    opacity 0.15s, transform 0.1s;
  text-align:    center;
}
.btn:hover  { opacity: 0.85; }
.btn:active { transform: scale(0.97); }

.btn-blue   { background: var(--blue);   color: #fff; }
.btn-red    { background: var(--red);    color: #fff; }
.btn-green  { background: var(--green);  color: #000; }
.btn-yellow { background: var(--yellow); color: #000; }
.btn-full   { width: 100%; padding: 0.6rem; font-size: 1rem; }

/* ── Card generica ── */
.card {
  background:    var(--bg-card);
  border-radius: 8px;
  overflow:      hidden;
  margin-bottom: 1rem;
}

/* Bordi colorati sulle card (usati per differenziare sezioni) */
.card-red    { border-left: 3px solid var(--red); }
.card-blue   { border-left: 3px solid var(--blue); }
.card-green  { border-left: 3px solid var(--green); }
.card-yellow { border-left: 3px solid var(--yellow); }

.card-body   { padding: 1rem; }
.card-header {
  padding:    0.6rem 1rem;
  font-weight: 600;
  font-size:  0.85rem;
  color:      var(--muted);
  border-bottom: 1px solid var(--border);
}

/* ── Testi utility ── */
.text-muted  { color: var(--muted); font-size: 0.8rem; }
.text-center { text-align: center; }
.mt-1 { margin-top: 0.5rem; }
.mt-2 { margin-top: 1rem; }
.mb-1 { margin-bottom: 0.5rem; }

/* ── Alert errore ── */
.alert-error {
  background:    #2a0808;
  border:        1px solid var(--red);
  border-radius: 6px;
  color:         #f88;
  padding:       0.6rem 0.9rem;
  font-size:     0.88rem;
  margin-bottom: 1rem;
}
</style>
