<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ErMike-SocialHub · Home</title>

  <link rel="stylesheet" href="img/css/style.css">

  <%- include('partials/styles') %>
  <!--<style>
    /* ── Layout pagina centrato ── */
    .page { max-width: 600px; margin: 0 auto; padding: 1.2rem 1rem; }

    /* ── Card "crea post" ── */
