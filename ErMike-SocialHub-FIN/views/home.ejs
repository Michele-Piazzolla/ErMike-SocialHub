    .post-card     { border-left: 3px solid var(--blue); }
    .post-username { font-weight: 700; color: var(--blue); }
    .post-meta     { font-size: 0.78rem; color: var(--muted); font-style: italic; }
    .post-text     { margin-top: 0.6rem; line-height: 1.6; }
    .post-img      { width: 100%; max-height: 400px; object-fit: cover; border-radius: 6px; margin-top: 0.7rem; }

    /* ── Barra azioni sotto ogni post ── */
    .post-actions {
      display:       flex;
      align-items:   center;
      gap:           0.5rem;
      padding:       0.5rem 1rem;
      border-top:    1px solid #222;
      /* la barra azioni è leggermente rientrata rispetto al body */
    }

    /* Bottone generico azione (like, commenta, elimina) */
    .action-btn {
      background:    transparent;
      border:        1px solid #333;
      border-radius: 20px;
      color:         var(--text);
      padding:       0.28rem 0.8rem;
      font-size:     0.82rem;
      cursor:        pointer;
      transition:    background 0.15s, color 0.15s, border-color 0.15s;
    }
    .action-btn:hover           { border-color: var(--blue); color: var(--blue); }
    .action-btn.liked           { border-color: var(--red); color: var(--red); }
    /* Il bottone elimina va sempre a destra */
    .action-btn.delete-btn      { margin-left: auto; border-color: #3a1a1a; color: #955; }
    .action-btn.delete-btn:hover{ border-color: var(--red); color: var(--red); background: #1a0808; }

    /* Bottone "commenta" aperto → bordo verde */
    .action-btn.comment-open    { border-color: var(--green); color: var(--green); }

    /* ── Sezione commenti (nascosta di default) ── */
    .comments-section {
      display:    none;         /* nascosta: viene mostrata dal JS al click su "Commenta" */
      padding:    0.8rem 1rem;
      border-top: 1px solid #1e1e1e;
    }
    .comments-section.open { display: block; }

    /* Singolo commento nel feed */
    .comment-item {
      display:       flex;
      gap:           0.5rem;
      margin-bottom: 0.6rem;
      font-size:     0.88rem;
    }
    .comment-item-avatar {
      width:           28px; height: 28px;
      border-radius:   50%;
      background:      var(--blue);
      color:           #fff;
      font-size:       0.75rem;
      font-weight:     700;
      display:         flex;
      align-items:     center;
      justify-content: center;
      flex-shrink:     0;
    }
    .comment-author { font-weight: 700; color: var(--blue); margin-right: 0.3rem; }
