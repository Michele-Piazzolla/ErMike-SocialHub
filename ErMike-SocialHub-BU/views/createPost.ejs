<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ErMike-SocialHub · Nuovo post</title>
  <%- include('partials/styles') %>
  <style>
    .page      { max-width: 560px; margin: 2rem auto; padding: 0 1rem; }
    .post-card { border-top: 3px solid var(--red); }
    .post-card .card-header { color: var(--red); font-size: 1rem; }

    label      { display:block; font-size:0.85rem; color:#aaa; margin-bottom:0.35rem; margin-top:0.9rem; }
    textarea   { min-height: 100px; resize: vertical; }

    /* Anteprima immagine scelta */
    #preview {
      display:       none;
      width:         100%;
      max-height:    280px;
      object-fit:    cover;
      border-radius: 6px;
      margin-top:    0.7rem;
      border:        1px solid var(--border);
    }

    .btn-row { display:flex; gap:0.7rem; margin-top:1.2rem; }
  </style>
</head>
<body>

  <%- include('partials/navbar') %>

  <div class="page">
    <div class="card post-card">
      <div class="card-header">📝 Nuovo post</div>
      <div class="card-body">

        <% if (error) { %>
          <div class="alert-error">⚠️ <%= error %></div>
        <% } %>

        <!--
          enctype="multipart/form-data" è OBBLIGATORIO quando si caricano file.
          Senza di esso, multer non riceve l'immagine.
        -->
        <form action="/create-post" method="POST" enctype="multipart/form-data">

          <label>Testo del post</label>
          <textarea name="text" placeholder="Scrivi qualcosa..."></textarea>

          <label>Immagine (opzionale)</label>
          <!--
            Il campo si chiama "image" — deve corrispondere al nome usato
            in server.js: upload.single('image')
          -->
          <input type="file" name="image" accept="image/*"
                 style="color:var(--muted); margin-top:0.2rem;"
                 onchange="mostraAnteprima(this)">

          <!-- Anteprima dell'immagine selezionata (JavaScript sotto) -->
          <img id="preview" alt="Anteprima">

          <div class="btn-row">
            <button type="submit" class="btn btn-red">📤 Pubblica</button>
            <a href="/home" class="btn" style="background:#333; color:#aaa;">Annulla</a>
          </div>

        </form>
      </div>
    </div>
  </div>

  <script>
    /* Mostra l'anteprima dell'immagine scelta prima di inviarla */
    function mostraAnteprima(input) {
      const preview = document.getElementById('preview');
      if (input.files && input.files[0]) {
        // FileReader legge il file localmente senza caricarlo sul server
        const reader = new FileReader();
        reader.onload = e => {
          preview.src           = e.target.result;
          preview.style.display = 'block';
        };
        reader.readAsDataURL(input.files[0]);
      } else {
        preview.style.display = 'none';
      }
    }
  </script>

</body>
</html>
